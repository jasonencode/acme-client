{
  "name": "jason/acme-client",
  "description": "ACME client: a decoupled LetsEncrypt client",
  "type": "package",
  "keywords": [],
  "homepage": "https://github.com/jasonencode/acme-client",
  "license": "MIT",
  "authors": [
    {
      "name": "Jason.Chen",
      "homepage": "https://github.com/jasonencode"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-openssl": "*",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.0",
    "league/flysystem": "^3.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.5",
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "phpstan/phpstan-mockery": "^1.1",
    "phpstan/extension-installer": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "Jason\\Acme\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Jason\\Acme\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "stable"
}
